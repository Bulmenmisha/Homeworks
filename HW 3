<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <title>Карточки Flexbox</title>
</head>
<body>

<div class="container">

    <div class="card">
        <img src="https://picsum.photos/300/200?1" alt="image">
        <div class="card-title">Карточка 1</div>
    </div>

    <div class="card">
        <img src="https://picsum.photos/300/200?2" alt="image">
        <div class="card-title">Карточка 2</div>
    </div>

    <div class="card">
        <img src="https://picsum.photos/300/200?3" alt="image">
        <div class="card-title">Карточка 3</div>
    </div>

    <div class="card">
        <img src="https://picsum.photos/300/200?4" alt="image">
        <div class="card-title">Карточка 4</div>
    </div>

</div>

</body>
</html>




body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
}

.container {
    display: flex;
    flex-wrap: wrap; 
    gap: 20px;
    padding: 20px;
}

.card {
    flex: 1 1 250px; 
    max-width: 300px;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: transform 0.2s ease;
}

.card:hover {
    transform: translateY(-5px);
}

.card img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.card-title {
    padding: 15px;
    font-size: 18px;
    font-weight: bold;
    text-align: center;
}

@media (max-width: 768px) {
    .card {
        flex: 1 1 45%;
    }
}

@media (max-width: 480px) {
    .card {
        flex: 1 1 100%;
    }
}
